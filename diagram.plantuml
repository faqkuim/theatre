@startuml theatre_er

' ════════════════════════════════════════════
'  LAYOUT
' ════════════════════════════════════════════
skinparam linetype ortho
skinparam ranksep 70
skinparam nodesep 50
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam shadowing false
skinparam roundCorner 4

' ════════════════════════════════════════════
'  ENTITY STYLE
' ════════════════════════════════════════════
skinparam entity {
  BackgroundColor       #FFFFFF
  BorderColor           #888888
  FontColor             #000000
  HeaderBackgroundColor #EEEEEE
  HeaderFontColor       #000000
  HeaderFontSize        11
  HeaderFontStyle       bold
  AttributeFontSize     10
}

skinparam arrow {
  Color     #CC0000
  FontColor #CC0000
  FontSize  9
}

' ════════════════════════════════════════════
'  ENTITIES  (точно по PDF — 13 таблиц)
'  * = PK   # = FK
' ════════════════════════════════════════════

entity "admin_setting" {
  * id      : int <>
  --
  * skey    : varchar(100)
  svalue    : text
}

entity "auth_log" {
  * id              : bigint <>
  --
  # user_id         : bigint
  created_at        : datetime
  attempted_login   : varchar(64)
  ip                : varchar(64)
  user_agent        : varchar(255)
  is_success        : tinyint(1)
  reason            : varchar(255)
}

entity "backup_log" {
  * id          : bigint <>
  --
  started_at    : datetime
  finished_at   : datetime
  status        : varchar(32)
  location      : varchar(255)
  message       : varchar(255)
}

entity "email_queue" {
  * id       : bigint <>
  --
  to_email   : varchar(255)
  subject    : varchar(255)
  body       : text
  sent_at    : datetime
  is_sent    : tinyint(1)
  error_msg  : varchar(255)
}

entity "hall" {
  * id    : int <>
  --
  name    : varchar(120)
}

entity "integration" {
  * id       : int <>
  --
  provider   : varchar(64)
  config     : text
}

entity "payment_method" {
  * id    : int <>
  --
  * code  : varchar(32) <>
  name    : varchar(64)
}

entity "permissions" {
  * id    : int <>
  --
  * code  : varchar(64) <>
  name    : varchar(128)
}

entity "production" {
  * id           : int <>
  --
  title          : varchar(200)
  genre          : varchar(80)
  description    : text
  duration_min   : int
  age_rating     : varchar(16)
}

entity "roles" {
  * id    : int <>
  --
  * code  : varchar(50) <>
  name    : varchar(100)
}

entity "role_permissions" {
  # role_id       : int <>
  # permission_id : int <>
}

entity "seat_zone" {
  * id         : int <>
  --
  # hall_id    : int <>
  name         : varchar(80)
  price_mult   : decimal(6,2)
}

entity "users" {
  * id            : bigint <>
  --
  * login         : varchar(64) <>
  password_hash   : varchar(255)
  full_name       : varchar(200)
  phone           : varchar(20)
  email           : varchar(255)
  # role_id       : int <>
  is_active       : tinyint(1)
  created_at      : datetime
  updated_at      : datetime
}

' ════════════════════════════════════════════
'  RELATIONSHIPS  (по PDF — ссылки из phpMyAdmin)
' ════════════════════════════════════════════

roles       ||--o{ users            : "role_id -> roles.id"
roles       ||--o{ role_permissions : "role_id -> roles.id"
permissions ||--o{ role_permissions : "permission_id -> permissions.id"
users       ||--o{ auth_log         : "user_id -> users.id"
hall        ||--o{ seat_zone        : "hall_id -> hall.id"

@enduml
